# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Environment files
.env
.env.*
!.envrc
!.env.example

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Node + Cloudflare tooling
node_modules/
dist/
.wrangler-tmp/

# Local-only configs
*.local
*.local.yaml
config.local.*

# Secrets and credentials (defensive — should never be committed)
secrets/
*.pem
*.key

# Backtest price cache (regenerable from yfinance; large parquet blob
# and we don't want stale cached prices accidentally committed)
backtest_cache/
.wrangler/

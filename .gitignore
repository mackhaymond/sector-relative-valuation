# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
.poetry/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Environment files
.env
.env.*
!.envrc

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Node (only present if tooling is added later)
node_modules/

# Local-only configs
*.local
*.local.yaml
config.local.*

# Secrets and credentials (defensive — should never be committed)
secrets/
*.pem
*.key

# SimFin free-tier API key for point-in-time fundamentals.
# Sign up at https://www.simfin.com/en/ — free, no credit card.
# Used by src/pit_fundamentals.py (loaded by src/backtest.py) to fetch
# historical filings whose publish_date is used as the as-of cutoff,
# eliminating the look-ahead bias of yfinance's current-snapshot info.
SIMFIN_API_KEY=your_simfin_key_here
